body
    font-family 'Open Sans',sans-serif
    font-size 14px
    line-height 26px
    color #6b6e80

a
    color #5d9cec
    -webkit-transition all .2s ease-in-out
    -moz-transition all .2s ease-in-out
    -ms-transition all .2s ease-in-out
    -o-transition all .2s ease-in-out
    transition all .2s ease-in-out
    &:hover
        color #4a89dc
        -webkit-transition all .2s ease-in-out
        -moz-transition all .2s ease-in-out
        -ms-transition all .2s ease-in-out
        -o-transition all .2s ease-in-out
        transition all .2s ease-in-out

h1, h2, h3, h4, h5, h6
    font-weight 700
    
.page-title
    padding 0
    margin-bottom 30px
    display block
    border-bottom 1px solid #ddd
    h2
        position relative
        display inline-block
        margin-top 0
        margin-bottom 10px
        font-weight 700
        &::after
            content ''
            position absolute
            left 0
            bottom 0
            margin-bottom -11px
            width 100%
            height 2px
            background-color #6b6e80
    &.title-center
        text-align center

.heading-title
    display block
    margin-bottom 20px
    h2
        font-weight 700
        color #434a54
        margin 0
        font-size 24px
        line-height 28px
    h3
        font-weight 700
        color #434a54
        margin 0
        font-size 20px
        line-height 24px