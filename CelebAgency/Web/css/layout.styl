body
    margin 0
    padding 80px 0 0
    background-color #f7f7f7
    background-image url(../img/bk.png)
    background-repeat repeat

.resize-none
    resize none

.form-control
    &:focus
        -webkit-box-shadow none
        -moz-box-shadow none
        -ms-box-shadow none
        -o-box-shadow none
        box-shadow none
        border-color #ddd

.navbar-inverse .navbar-brand strong
    font-weight 700

.dropdown-menu
    padding-top 0
    padding-bottom 0
    border none
    border-top 1px solid #ddd
    background-color #fff
    & > li
        & > a
            color #434a54
            padding 10px 20px
            &:hover
                background-color #4a89dc
                color #fff

.dropdown-menu>.active:last-child>a,.dropdown-menu>.active:last-child>a:focus,.dropdown-menu>.active:last-child>a:hover,.dropdown-menu>li:last-child>a:focus,.dropdown-menu>li:last-child>a:hover
    border-radius 0 0 4px 4px

.btn-search
    &:hover
        cursor pointer
    &::before
        font-family FontAwesome
        content '\f00e'
    &.active
        &::before
            font-family FontAwesome
            content '\f010'

#searchbox
    position fixed
    left 0
    top 50px
    z-index 3
    width 100%
    padding 25px 0 15px
    background-color #f8f8f8
    -webkit-box-shadow 0 1px 3px rgba(0,0,0,.2)
    -moz-box-shadow 0 1px 3px rgba(0,0,0,.2)
    -ms-box-shadow 0 1px 3px rgba(0,0,0,.2)
    -o-box-shadow 0 1px 3px rgba(0,0,0,.2)
    box-shadow 0 1px 3px rgba(0,0,0,.2)
    visibility hidden
    opacity 0
    -webkit-transition all .3s ease-in-out
    -moz-transition all .3s ease-in-out
    -ms-transition all .3s ease-in-out
    -o-transition all .3s ease-in-out
    transition all .3s ease-in-out
    .form-control
        -webkit-border-radius 24px
        -moz-border-radius 24px
        -ms-border-radius 24px
        -o-border-radius 24px
        border-radius 24px
    &.searchbox-show
        visibility visible
        opacity 1
        -webkit-transition all .3s ease-in-out
        -moz-transition all .3s ease-in-out
        -ms-transition all .3s ease-in-out
        -o-transition all .3s ease-in-out
        transition all .3s ease-in-out

#content
    width 100%
    height auto

.sidebar-menu
    background-color #fff
    .nav-stacked
        & > li
            & + li
                margin-top 0
    .nav-pills
        & > li
            & > a
                padding 6px 15px
                border-top 1px solid #ddd
                -webkit-border-radius 0
                -moz-border-radius 0
                -ms-border-radius 0
                -o-border-radius 0
                border-radius 0
                -webkit-box-sizing border-box
                -moz-box-sizing border-box
                -ms-box-sizing border-box
                -o-box-sizing border-box
                box-sizing border-box

.sidebar-menu .nav-pills>.active>a,.sidebar-menu .nav-pills>.active>a:focus,.sidebar-menu .nav-pills>.active>a:hover,.sidebar-menu .nav-pills>li>a:focus,.sidebar-menu .nav-pills>li>a:hover
    background-color #f6f6f6
    color #434a54

.team-container
    position relative
    width auto
    height auto
    margin-bottom 20px
    text-align center
    .team-img
        display block
        margin 0 auto 20px
        width 160px
        height 160px
        border 4px solid transparent
        -webkit-box-sizing border-box
        -moz-box-sizing border-box
        -ms-box-sizing border-box
        -o-box-sizing border-box
        box-sizing border-box
        -webkit-border-radius 100%
        -moz-border-radius 100%
        -ms-border-radius 100%
        -o-border-radius 100%
        border-radius 100%
        -webkit-box-shadow 0 0 3px 1px rgba(0,0,0,.15)
        -moz-box-shadow 0 0 3px 1px rgba(0,0,0,.15)
        -ms-box-shadow 0 0 3px 1px rgba(0,0,0,.15)
        -o-box-shadow 0 0 3px 1px rgba(0,0,0,.15)
        box-shadow 0 0 3px 1px rgba(0,0,0,.15)
        overflow hidden
        opacity .7
        -webkit-transition all .2s ease-in-out
        -moz-transition all .2s ease-in-out
        -ms-transition all .2s ease-in-out
        -o-transition all .2s ease-in-out
        transition all .2s ease-in-out
    &:hover
        & > .team-img
            opacity 1
            -webkit-transition all .2s ease-in-out
            -moz-transition all .2s ease-in-out
            -ms-transition all .2s ease-in-out
            -o-transition all .2s ease-in-out
            transition all .2s ease-in-out
    h3
        font-size 16px
        line-height 20px
        font-weight 700
        margin 0 0 20px
    .list-inline
        font-size 11px
        line-height 16px
        text-transform uppercase

.img-partners
    display block
    margin-left auto
    margin-right auto

.img-avatar
    width 32px
    height 32px
    float left
    margin-right 20px!important
    margin-top -6px

.profile-account
    font-size 13px
    line-height 18px
    img
        display block
        margin-left auto
        margin-right auto
        margin-bottom 20px
    h3
        margin 0 0 20px
        font-size 20px
        line-height 24px
        font-weight 700
        text-align center

.nav-filter
    padding 0 0 40px
    .nav-pills
        display table
        margin-left auto
        margin-right auto
        & > li
            & > a
                padding 8px 24px
                margin 5px
                background 0 0
                border 1px solid #434a54
                color #6b6e80
                &:hover
                    background #434a54
                    border 1px solid #434a54
                    color #fff

.nav-filter .nav-pills>.active>a,.nav-filter .nav-pills>.active>a:active,.nav-filter .nav-pills>.active>a:focus,.nav-filter .nav-pills>.active>a:hover,.nav-filter .nav-pills>li>a.active,.nav-filter .nav-pills>li>a.active:active,.nav-filter .nav-pills>li>a.active:focus,.nav-filter .nav-pills>li>a.active:hover
    color #fff
    background-color #434a54
    border 1px solid #434a54

.detail-option
    position relative
    width 100%
    .list-options
        display table
        width 100%
        margin 0
        padding 0
        list-style-type none
        & > li
            display table-cell
            width 25%
            & > a
                display block
                text-align center
                font-size 18px
                line-height 26px
                color #6b6e80
                &:hover
                    color #434a54
                    text-decoration underline
                span
                    display block
                    padding 3px 0
                    text-align center
                    font-size 9px
                    line-height 9px
                    font-weight 400
                    text-transform uppercase

.widget-title
    margin 0 0 20px
    padding-bottom 10px
    display block
    border-bottom 1px solid #ddd
    h3
        position relative
        display inline-block
        margin 0
        font-size 18px
        line-height 20px
        color #434a54
        font-weight 700
        &::after
            content ''
            position absolute
            left 0
            bottom -16px
            display block
            width 100%
            border-bottom 2px solid #434a54

.widget-content
    padding 0
    margin 0
    ul
        list-style-type none
        padding 0
        margin 0
        & > li
            & > a
                position relative
                display block
                padding 8px 0
                border-bottom 1px solid #ddd
                color #6b6e80
                &:after
                    font-family FontAwesome
                    content '\f105'
                    position absolute
                    right 0
                    padding-left 15px
                &:hover
                    color #428bca
                    text-decoration none
    &.popular-post
        ul
            & > li
                & > a
                    font-weight 700
                    font-size 15px
                    line-height 20px
                    span
                        display block
                        font-size 11px
                        color #999
                        font-weight 400
                        font-style italic
                    &:after
                        content ''
                        padding 0
                        margin 0

.detail-similiar
    position relative
    display block
    width 100%
    .list-similiars
        display inline-block
        width 100%
        height auto
        list-style-type none
        margin 0 0 -7px
        padding 0
        min-height 30px
        background-color #fff
        & > li
            display block
            width 33.3333%
            float left
            margin-bottom 0
            padding-bottom 0
    .list-options
        & > li
            img
                margin-bottom 0!important

.detail-meta
    display block
    padding-top 5px
    padding-bottom 5px
    span
        font-size 12px
        line-height 16px
        text-transform uppercase
        em
            text-transform none
            color #999

.detail-heading-title
    margin-bottom 40px
    h2
        padding-bottom 15px
        margin-bottom 20px
        font-size 32px
        line-height 36px
        font-weight 700
        border-bottom 1px solid #eee
        text-transform uppercase

.tags
    margin-left 0
    padding-left 0
    & > li
        position relative
        display inline-block
        & > a
            position relative
            display block
            background-color #fff
            border 1px solid #6b6e80
            padding 5px 12px 5px 10px
            font-size 13px
            line-height 18px
            margin-right 20px
            color #6b6e80
            -webkit-border-radius 2px 0 0 2px
            -moz-border-radius 2px 0 0 2px
            -ms-border-radius 2px 0 0 2px
            -o-border-radius 2px 0 0 2px
            border-radius 2px 0 0 2px
            margin-bottom 10px
            &::after
                content ''
                position absolute
                z-index 1
                right -15px
                top 0
                border-top 14px solid transparent
                border-right 0 solid transparent
                border-bottom 14px solid transparent
                border-left 14px solid #434a54
                -webkit-transition all .2s ease-in-out
                -moz-transition all .2s ease-in-out
                -ms-transition all .2s ease-in-out
                -o-transition all .2s ease-in-out
                transition all .2s ease-in-out
            &::before
                content ''
                position absolute
                z-index 2
                right -14px
                top 0
                border-top 14px solid transparent
                border-right 0 solid transparent
                border-bottom 14px solid transparent
                border-left 14px solid #fff
                -webkit-transition all .2s ease-in-out
                -moz-transition all .2s ease-in-out
                -ms-transition all .2s ease-in-out
                -o-transition all .2s ease-in-out
                transition all .2s ease-in-out
            &:hover
                background-color #6b6e80
                border-color #6b6e80
                color #fff
                text-decoration none
        &::before
            content ''
            position absolute
            z-index 3
            right 18px
            top 12px
            width 6px
            height 6px
            border 1px solid #6b6e80
            -webkit-border-radius 5px
            -moz-border-radius 5px
            -ms-border-radius 5px
            -o-border-radius 5px
            border-radius 5px
            background-color #fff

.tags>li>a:hover::after,.tags>li>a:hover::before
    content ''
    border-left-color #6b6e80
    -webkit-transition all .2s ease-in-out
    -moz-transition all .2s ease-in-out
    -ms-transition all .2s ease-in-out
    -o-transition all .2s ease-in-out
    transition all .2s ease-in-out

.form-signin
    .input-group
        margin-bottom 10px
    .control-label
        font-weight 400
        font-size 13px
        line-height 20px
        text-align left
    .btn-signin
        text-align right

.fa-tw,.form-signin .fa-tw
    color #4099ff

.fa-fb,.form-signin .fa-fb
    color #4467ad

.fa-gp,.form-signin .fa-gp
    color #ff4b4b

.related-posts
    margin-bottom 40px

.about-author
    display block
    padding 20px
    margin 60px 0
    background-color #fff
    border 1px solid #ddd
    -webkit-border-radius 2px
    -moz-border-radius 2px
    -ms-border-radius 2px
    -o-border-radius 2px
    border-radius 2px
    .author-left
        width 80px
        height 80px
        float left
        margin-top 10px
        margin-right 20px
        margin-bottom 10px
        -webkit-border-radius 100%
        -moz-border-radius 100%
        -ms-border-radius 100%
        -o-border-radius 100%
        border-radius 100%
        overflow hidden
        img
            max-width 100%
    .author-right
        h4
            margin 0 0 15px
            font-size 16px
            line-height 20px
            color #434a54
            text-transform uppercase
            small
                font-weight 400
                text-transform uppercase
                font-size 12px
                line-height 18px
                color #6b6e80
        p
            font-size 14px
            line-height 24px

.comments-container
    display block
    padding 0
    margin-bottom 60px
    ul
        list-style-type none
        padding 0
        margin 0
        li
            ul
                margin-left 60px
    .comments-item
        margin-bottom 15px
        padding 20px
        border 1px solid #eee
        -webkit-border-radius 2px
        -moz-border-radius 2px
        -ms-border-radius 2px
        -o-border-radius 2px
        border-radius 2px
        background-color #fff

.comments-item
    .comments-item-left
        width 50px
        height 50px
        float left
        overflow hidden
        img
            max-width 100%
    .comments-item-right
        display block
        margin-left 70px

.comments-item-right
    .item-right-author
        h4
            margin 0
            font-size 16px
            line-height 22px
        .reply-link
            float right
            margin 0
            font-size 12px
            text-transform uppercase
            a
                &:hover
                    text-decoration none
    .item-right-date
        display block
        margin-bottom 5px
        font-size 13px
        color #999
    .item-right-comment
        font-size 15px
        line-height 28px
        color #434a54

.comments-container .children,.comments-container .comments-reply-container
    position relative

.comments-container .children::before,.comments-container .comments-reply-container::before
    content ''
    position absolute
    left -60px
    top 0
    width 1px
    height 100%
    background-color #eee

.comments-container .children::after,.comments-container .comments-reply-container::after
    content ''
    position absolute
    left -60px
    top 50px
    width 60px
    height 1px
    background-color #eee

.footer
    width 100%
    padding 40px 0
    color #434a54
    a
        color #434a54
        text-decoration underline
        &:hover
            color #333
            text-decoration none
    hr
        border-top 1px solid #ccc
        border-bottom 1px solid #fff
    .list-social
        float right
        list-style-type none
        & > li
            display inline-block
            & > a
                position relative
                z-index 3
                display block
                width 35px
                height 35px
                margin-right 20px
                margin-bottom 10px
                text-align center
                color #999
                -webkit-border-radius 100%
                -moz-border-radius 100%
                -ms-border-radius 100%
                -o-border-radius 100%
                border-radius 100%
                border 1px solid #999
                -webkit-transform rotateY(0deg)
                -moz-transform rotateY(0deg)
                -ms-transform rotateY(0deg)
                -o-transform rotateY(0deg)
                transform rotateY(0deg)
                -webkit-transition all .3s ease-in-out
                -moz-transition all .3s ease-in-out
                -ms-transition all .3s ease-in-out
                -o-transition all .3s ease-in-out
                transition all .3s ease-in-out
            &:last-child
                & > a
                    margin-right 0
            &:hover
                & > a
                    border 1px solid #333
                    color #333
                    -webkit-transform rotate(360deg)
                    -moz-transform rotate(360deg)
                    -ms-transform rotate(360deg)
                    -o-transform rotate(360deg)
                    transform rotate(360deg)
                    -webkit-transition all .3s ease-in-out
                    -moz-transition all .3s ease-in-out
                    -ms-transition all .3s ease-in-out
                    -o-transition all .3s ease-in-out
                    transition all .3s ease-in-out

.footer .list-social>li>a>.fa,.footer .list-social>li>a>.glyphicon
    position absolute
    left 50%
    top 50%
    margin-left -10px
    margin-top -10px
    width 20px
    height 20px
    text-align center
    font-size 20px
    line-height 20px